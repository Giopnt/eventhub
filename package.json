{
  "name": "eventhub",
  "version": "1.0.0",
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap/cds": "^9",
    "@sap/xssec": "^4"
  },
  "devDependencies": {
    "@cap-js/cds-test": "^1.0.1",
    "@cap-js/sqlite": "^2.4",
    "@sap/cds-dk": "^9",
    "cds-plugin-ui5": "^0.17.0"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-eventmgmt": "cds watch --open eventhub.eventmgmt/index.html?sap-ui-xx-viewCache=false --livereload false",
    "test": "npx jest --testPathPatterns=tests/"
  },
  "private": true,
  "cds": {
    "requires": {
      "[production]": {
        "auth": "xsuaa",
        "db": "hana"
      },
      "[development]": {
        "auth": {
          "kind": "mocked",
          "users": {
            "alice": {
              "password": "alice",
              "roles": [
                "viewer"
              ]
            },
            "admin": {
              "password": "admin",
              "roles": [
                "admin",
                "viewer"
              ]
            }
          }
        }
      },
      "destinations": true,
      "html5-repo": true,
      "workzone": true
    }
  },
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/eventmgmt"
  ]
}
